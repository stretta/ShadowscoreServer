[Unit]
Description=ShadowscoreServer peer registration agent
Wants=network-online.target
After=network-online.target shadowscore-server.service

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/ShadowscoreServer
ExecStart=/usr/bin/npm run agent -- --config /home/pi/ShadowscoreServer/config/shadowbox.hardware-peer.json
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
