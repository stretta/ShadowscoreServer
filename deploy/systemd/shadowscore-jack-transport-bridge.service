[Unit]
Description=ShadowscoreServer JACK transport bridge
Wants=network-online.target shadowscore-server.service
After=network-online.target shadowscore-server.service

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/ShadowscoreServer
ExecStart=/usr/bin/python3 bin/jack-transport-bridge.py --host shadowbox-host --url http://127.0.0.1:8790/transport/jack/snapshot --interval 0.075
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
